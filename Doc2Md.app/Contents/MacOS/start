#!/bin/bash
# Doc2Md Mac App 启动器

# 获取 .app 所在的父目录（项目根目录）
SCRIPT_PATH="$(cd "$(dirname "$0")" && pwd)"
APP_BUNDLE="$(dirname "$(dirname "$SCRIPT_PATH")")"
APP_DIR="$(dirname "$APP_BUNDLE")"

# 日志文件
LOG_FILE="$HOME/.doc2md.log"

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$LOG_FILE"
}

log "=== Doc2Md 启动 ==="
log "APP_DIR: $APP_DIR"

# 检查虚拟环境
VENV_PYTHON="$APP_DIR/venv/bin/python3"
if [ ! -f "$VENV_PYTHON" ]; then
    log "错误: 虚拟环境不存在"
    osascript -e 'display dialog "请先运行 install.sh 安装依赖" buttons {"确定"} default button "确定" with title "Doc2Md 错误"'
    exit 1
fi

# 设置环境变量
export HF_ENDPOINT=https://hf-mirror.com
export TRANSFORMERS_OFFLINE=1

# 启动应用（使用绝对路径避免权限问题）
cd "$APP_DIR"
log "启动应用..."

# 使用 osascript 在终端中运行，避免权限问题
osascript <<EOF
tell application "Terminal"
    activate
    do script "cd '$APP_DIR' && source venv/bin/activate && export HF_ENDPOINT=https://hf-mirror.com && python3 app.py"
end tell
EOF

log "已在终端中启动"
